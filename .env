# ────────────────────────────────────────────────────────────────────────────
# M5 — Contact Form SMTP Configuration
# ────────────────────────────────────────────────────────────────────────────
# Fill in your SMTP credentials below.
#
# Required vars:
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_or_smtp_password
MAIL_DEFAULT_RECIPIENT=piyushmahendru534@gmail.com

# Optional, Flask defaults:
FLASK_ENV=development
SECRET_KEY=generate-a-random-secret-key-here

# Flask-Mail connection flags:
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# ── Gmail-specific notes ──
# If using Gmail:
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use that 16-char app password as MAIL_PASSWORD
#   4. MAIL_SERVER=smtp.gmail.com, MAIL_PORT=587, MAIL_USE_TLS=True
#
# ── Other providers ──
# SendGrid:   MAIL_SERVER=smtp.sendgrid.net, MAIL_PORT=587, MAIL_USERNAME=apikey,
#             MAIL_PASSWORD=<SendGrid API key>
# Mailgun:    MAIL_SERVER=smtp.mailgun.org, MAIL_PORT=587
# Outlook:    MAIL_SERVER=smtp-mail.outlook.com, MAIL_PORT=587
# Zoho:       MAIL_SERVER=smtp.zoho.com, MAIL_PORT=587
